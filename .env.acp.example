# Standalone ACP host config — copy to `.env.acp` (gitignored) and fill in.
# Loaded by scripts/run-acp-host.sh, which runs OCRC against a spawned ACP agent
# (kimi/gemini/…) with NO opencode. Values here OVERRIDE the repo .env so the host
# never collides with a running opencode hub.

# The ACP agent to spawn. Must be logged in already (e.g. `kimi login`).
OCRC_ACP_CMD=kimi acp

# Web — token auth. Pick any long random string; you pair the device with it.
WEB_ENABLED=true
WEB_PORT=17085            # MUST differ from the opencode hub's port (17081)
WEB_AUTH=token
WEB_TOKEN=change-me-to-a-long-random-string
WEB_CF_ACCESS_DEV_BYPASS=false

# Telegram — OPTIONAL. Leave BOTH unset for a web-only host (simplest; no bot,
# no conflict with the hub). To also test Telegram, create a SEPARATE bot via
# @BotFather (reusing the hub's bot token causes a 409 polling conflict).
# TELEGRAM_BOT_TOKEN=123456:your-SECOND-test-bot-token
# ALLOWED_USER_IDS=<your numeric telegram id>

# Tool-call approval. Default is INTERACTIVE (approve/deny in Web/Telegram).
# Set true to auto-approve once, unattended.
# OCRC_ACP_AUTO_APPROVE=true
