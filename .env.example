# Telegram Bot Token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Single allowed Telegram user ID (required)
ALLOWED_USER_ID=

# opencode server base URL (defaults to localhost:4096)
OPENCODE_BASE_URL=http://localhost:4096

# Stream edit throttle in ms (default 1000)
EDIT_THROTTLE_MS=1000

# Per-chat timeout in ms (default 600000 = 10 min)
CHAT_TIMEOUT_MS=600000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Stream output incrementally (true) or wait for full response (false)
STREAM_OUTPUT=true

# Comma-separated list of favourite models shown in /model (provider/modelId format)
# Leave empty to show the current default model per provider
# FAVOURITE_MODELS=opencode/big-pickle,deepseek/deepseek-v4-pro,google/gemini-3-pro-preview
