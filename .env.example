# Telegram Bot Token from @BotFather (required)
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot (required).
ALLOWED_USER_IDS=12345678,87654321

# Legacy single-user (deprecated; still works for backward compatibility).
# ALLOWED_USER_ID=12345678

# opencode server base URL (defaults to localhost:4096)
OPENCODE_BASE_URL=http://localhost:4096

# Per-chat timeout in ms (default 600000 = 10 min)
CHAT_TIMEOUT_MS=600000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Show inline tool calls (▸ bash · ls) during streaming (default true)
TOOL_CALLS_INLINE=true

# Mirror prompts into the opencode TUI's prompt buffer (default: true, set false to disable)
TUI_VISIBLE=true

# Where persistent state is stored (lastSessionId, nextAgent, nextModel)
STATE_PATH=./data/state.json

# Push notification when test failure detected in bash output (default true)
PUSH_TEST_FAILURES=true

# ── Telegram message pagination limits ──
TG_CHUNK_SOFT_LIMIT=3500
TG_CHUNK_HARD_LIMIT=3900

# ── Web UI ──
# Enable the web transport (serves PWA + WebSocket on WEB_HOST:WEB_PORT)
WEB_ENABLED=false

# Web server bind address and port (opencode 1.17's own server occupies 7081)
WEB_HOST=127.0.0.1
WEB_PORT=17081

# Static files root (built SvelteKit app)
WEB_STATIC_ROOT=web/dist

# Per-session card cache size for WebSocket replay
WEB_SESSION_CACHE_SIZE=100

# ── Web auth ──
# Strategy: token (default — app token, no Cloudflare Access needed) | cf-access
WEB_AUTH=token

# App token. Leave empty to auto-generate + persist (0600) at ~/.opencode/oprc-token.
# Onboard a device with `oprc pair` / Telegram `/pair` — it emits a URL/QR with the
# token in the fragment (#token=…); opening it once stores the token in the browser.
WEB_TOKEN=

# Public URL used for pairing links/QRs (falls back to LAN, then loopback).
# WEB_PUBLIC_URL=https://oprc.example.com

# Cloudflare Access (only when WEB_AUTH=cf-access)
WEB_CF_ACCESS_TEAM=
WEB_CF_ACCESS_AUD=

# Dev bypass: skip auth — ONLY for a real loopback socket peer. MUST stay false
# behind a Cloudflare Tunnel: cloudflared connects from 127.0.0.1, so a loopback
# bypass would trust ALL tunnel traffic. Uncomment only for bare-metal debugging
# with no tunnel in front.
# WEB_CF_ACCESS_DEV_BYPASS=true
# WEB_CF_ACCESS_DEV_EMAIL=dev@localhost
