{
  "name": "opencode-remote-control",
  "version": "0.1.0",
  "description": "Sidecar Telegram bot for remote-controlling a local opencode TUI session (umbrella project for future channels)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/launcher.js",
    "start:dev": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration"
  },
  "bin": {
    "opencode-remote-control": "dist/launcher.js",
    "oprc": "dist/launcher.js"
  },
  "dependencies": {
    "@opencode-ai/sdk": "^1.14.0",
    "dotenv": "^16.4.5",
    "telegraf": "^4.16.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
